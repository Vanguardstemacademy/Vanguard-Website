    { "source": "/formB.html", "destination": "/formB", "permanent": true },
    { "source": "/get-involved-form.html", "destination": "/get-involved-form", "permanent": true },
    { "source": "/icp-registration.html", "destination": "/icp-registration", "permanent": true },

    { "source": "/onboarding-application", "destination": "/apply-to-the-academy", "permanent": true },
    { "source": "/onboarding-application/:path*", "destination": "/apply-to-the-academy", "permanent": true }
  ],
  "rewrites": [
    { "source": "/:page/assets/:path*", "destination": "/assets/:path*" },

    { "source": "/home", "destination": "/pages/home" },
    { "source": "/home/:section", "destination": "/pages/home" },
    { "source": "/programs", "destination": "/pages/programs" },
    { "source": "/programs/:section", "destination": "/pages/programs" },
    { "source": "/the-academy", "destination": "/pages/academy" },
    { "source": "/the-academy/:section", "destination": "/pages/academy" },
    { "source": "/our-impact", "destination": "/pages/impact" },
    { "source": "/our-impact/:section", "destination": "/pages/impact" },
    { "source": "/the-leadership-team", "destination": "/pages/leadership" },
    { "source": "/get-involved", "destination": "/pages/get-involved" },
    { "source": "/get-involved/:section", "destination": "/pages/get-involved" },
    { "source": "/apply", "destination": "/pages/apply" },
    { "source": "/apply-to-the-academy", "destination": "/pages/apply" },
    { "source": "/individual-coaching-program-icp", "destination": "/pages/programs" },
    { "source": "/our-success-stories", "destination": "/pages/impact" },
    { "source": "/portal", "destination": "/pages/portal" },
    { "source": "/legal", "destination": "/pages/legal" },
