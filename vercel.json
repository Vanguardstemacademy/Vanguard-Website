    { "source": "/form-engineering-design", "destination": "/forms/engineering-design" },
    { "source": "/form-executive-leadership", "destination": "/forms/executive-leadership" },
    { "source": "/form-international-consulting", "destination": "/forms/international-consulting" },
    { "source": "/formA", "destination": "/forms/premium-program-inquiry" },
    { "source": "/formB", "destination": "/forms/icp-consultation-request" },
    { "source": "/get-involved-form", "destination": "/forms/get-involved-inquiry" },
    { "source": "/icp-registration", "destination": "/forms/icp-registration" },
    { "source": "/register-fireside-chat", "destination": "/forms/fireside-registration" }
  ]
}
