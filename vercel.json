    { "source": "/home.html", "destination": "/home", "permanent": true },
    { "source": "/programs.html", "destination": "/programs", "permanent": true },
    { "source": "/academy.html", "destination": "/the-academy", "permanent": true },
    { "source": "/academy", "destination": "/the-academy", "permanent": true },
