    { "source": "/leadership.html", "destination": "/the-leadership-team", "permanent": true },
    { "source": "/leadership", "destination": "/the-leadership-team", "permanent": true },
    { "source": "/get-involved.html", "destination": "/get-involved", "permanent": true },
    { "source": "/apply.html", "destination": "/apply", "permanent": true },
    { "source": "/portal.html", "destination": "/portal", "permanent": true },
    { "source": "/Vanguard-legal.html", "destination": "/legal", "permanent": true },
